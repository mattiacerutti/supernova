{
  "name": "@supernova/desktop",
  "private": true,
  "version": "0.0.1-alpha.1",
  "homepage": "https://github.com/mattiacerutti/supernova",
  "main": "./out/main/index.js",
  "scripts": {
    "lint": "eslint --cache .",
    "prettier": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit",
    "generate:icons": "bun ./scripts/generate-icons.ts",
    "predev": "bun ./scripts/generate-icons.ts",
    "prestart": "bun ./scripts/generate-icons.ts",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "prebuild": "bun ./scripts/generate-icons.ts",
    "build": "bun run typecheck && electron-vite build --ignoreConfigWarning",
    "postinstall": "electron-builder install-app-deps",
    "package:unpack": "bun run generate:icons && electron-builder --dir --publish never",
    "package:win": "bun run generate:icons && electron-builder --win --publish never",
    "package:mac": "bun run generate:icons && electron-builder --mac --publish never",
    "package:linux": "bun run generate:icons && electron-builder --linux --publish never"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@types/bun": "^1.3.14"
  },
  "devDependencies": {
    "@ctjs/png2icons": "^3.0.3",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "vite": "^7.2.6",
    "@types/node": "^22.19.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "sharp": "^0.34.5"
  }
}
