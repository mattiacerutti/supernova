{
  "name": "@supernova/server",
  "private": true,
  "version": "0.0.1-alpha.1",
  "type": "module",
  "bin": {
    "supernova-server": "./dist/cli.js"
  },
  "scripts": {
    "dev": "SUPERNOVA_SERVER_DEV=1 bun --watch src/bootstrap.ts",
    "start": "node dist/cli.js",
    "build": "rm -rf dist && bun build src/cli.ts src/bootstrap.ts --target node --outdir dist && cp -R ../../packages/web/dist dist/client && bun scripts/prepare-tools.ts",
    "lint": "eslint .",
    "prettier": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.60",
    "@hono/node-server": "^1.19.6",
    "@supernova/agent-runtime": "workspace:*",
    "@supernova/contracts": "workspace:*",
    "hono": "^4.11.2",
    "commander": "^14.0.2",
    "effect": "4.0.0-beta.60"
  },
  "devDependencies": {
    "@supernova/web": "workspace:*",
    "@types/node": "^22.19.1",
    "eslint": "^10.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
