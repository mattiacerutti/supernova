{
  "name": "supernova",
  "private": true,
  "packageManager": "bun@1.3.13",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:server": "turbo run dev --filter=@supernova/web --filter=@supernova/server",
    "dev:desktop": "turbo run dev --filter=@supernova/web --filter=@supernova/server --filter=@supernova/desktop",
    "start:server": "turbo run start --filter=@supernova/server",
    "start:desktop": "turbo run start --filter=@supernova/desktop",
    "build": "turbo run build",
    "package:desktop": "turbo run package:unpack --filter=@supernova/desktop",
    "package:desktop:win": "turbo run package:win --filter=@supernova/desktop",
    "package:desktop:mac": "turbo run package:mac --filter=@supernova/desktop",
    "package:desktop:linux": "turbo run package:linux --filter=@supernova/desktop",
    "lint": "turbo run lint",
    "prettier": "turbo run prettier",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "turbo": "^2.9.7"
  }
}
