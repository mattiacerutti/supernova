{
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "out/**"]
    },
    "package:unpack": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "package:win": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "package:mac": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "package:linux": {
      "dependsOn": ["build", "^build"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "prettier": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
