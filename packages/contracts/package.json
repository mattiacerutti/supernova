{
  "name": "@supernova/contracts",
  "private": true,
  "version": "0.0.1-alpha.4",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*/rpc": {
      "types": "./src/*/rpc.ts",
      "import": "./src/*/rpc.ts"
    },
    "./*/procedures": {
      "types": "./src/*/procedures/index.ts",
      "import": "./src/*/procedures/index.ts"
    },
    "./*/schemas": {
      "types": "./src/*/schemas/index.ts",
      "import": "./src/*/schemas/index.ts"
    }
  },
  "scripts": {
    "lint": "eslint .",
    "prettier": "prettier --check . --ignore-path ../../.prettierignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "4.0.0-beta.60"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  }
}
